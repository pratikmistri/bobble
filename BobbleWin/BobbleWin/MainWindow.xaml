<Window x:Class="BobbleWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:BobbleWin.Models"
        xmlns:views="clr-namespace:BobbleWin.Views"
        Title="Bobble"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp">

    <Window.Resources>
        <views:ProviderDisplayConverter x:Key="ProviderDisplayConverter" />
        <views:MessageRoleToAlignmentConverter x:Key="MessageRoleToAlignmentConverter" />
        <views:MessageRoleToBubbleBrushConverter x:Key="MessageRoleToBubbleBrushConverter" />
        <views:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <views:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <views:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <views:ChatHeadAvatarConverter x:Key="ChatHeadAvatarConverter" />
        <views:LayoutModeToOuterOrientationConverter x:Key="LayoutModeToOuterOrientationConverter" />
        <views:LayoutModeToInnerOrientationConverter x:Key="LayoutModeToInnerOrientationConverter" />
        <views:LayoutModeChatMarginConverter x:Key="LayoutModeChatMarginConverter" />
        <views:LayoutModeToToggleIconConverter x:Key="LayoutModeToToggleIconConverter" />
        <views:SessionStatusToBrushConverter x:Key="SessionStatusToBrushConverter" />
        <views:SessionToStatusVisibilityConverter x:Key="SessionToStatusVisibilityConverter" />
        <views:BackendBadgeTextConverter x:Key="BackendBadgeTextConverter" />
        <views:BackendBadgeBackgroundConverter x:Key="BackendBadgeBackgroundConverter" />
        <views:BackendBadgeForegroundConverter x:Key="BackendBadgeForegroundConverter" />
        <views:MessageRoleToMarkdownVisibilityConverter x:Key="MessageRoleToMarkdownVisibilityConverter" />
        <views:MessageRoleToPlainVisibilityConverter x:Key="MessageRoleToPlainVisibilityConverter" />
        <views:SessionStateKindIsRunningConverter x:Key="SessionStateKindIsRunningConverter" />

        <FontFamily x:Key="FluentIcons">Segoe Fluent Icons</FontFamily>

        <!-- Continuous bobble storyboard used while a session is working (Running). -->
        <Storyboard x:Key="WorkingBobble" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="1.04" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.64" Value="1.0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="0.96" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.64" Value="1.0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="-6" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.64" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="2" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.48" Value="-2" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.64" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- One-shot completion bounce triggered when a session transitions Running → Idle.
             Each cycle lasts 3 seconds: a ~0.62s jump followed by a 2.38s rest,
             repeating 5 times so the user gets gentle periodic nudges. -->
        <Storyboard x:Key="CompletedJump" RepeatBehavior="5x">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="-12">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.46" Value="4">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.62" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="0.96" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.46" Value="1.05" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.62" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.04" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.46" Value="0.95" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.62" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Style TargetType="Thumb" x:Key="ShyScrollThumb">
            <Setter Property="Background" Value="#80F3E9DF" />
            <Setter Property="Width" Value="4" />
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="MaxWidth" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="2" Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RepeatButton" x:Key="ShyScrollRepeat">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" x:Key="ShyScrollBar">
            <Setter Property="Width" Value="4" />
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="MaxWidth" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="4">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ShyScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ShyScrollRepeat}" Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ShyScrollRepeat}" Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource ShyScrollBar}" />

        <Style x:Key="CircleControlButton" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F3E9DF" />
            <Setter Property="FontFamily" Value="{StaticResource FluentIcons}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="#CC25221F" Stroke="#66F3E9DF" StrokeThickness="1" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animated chat-head button. -->
        <Style x:Key="HeadButton" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform X="0" Y="0" />
                        <RotateTransform Angle="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="#33000000" />
            <Setter Property="Foreground" Value="#F3E9DF" />
            <Setter Property="BorderBrush" Value="#66544A41" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="{StaticResource FluentIcons}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid x:Name="OuterLayout"
              HorizontalAlignment="Right"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Expanded chat panel (visible when a session is selected) -->
            <Border x:Name="ChatPanel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Width="340"
                    Height="500"
                    Background="#F22E2A26"
                    BorderBrush="#66544A41"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12"
                    Visibility="{Binding SelectedSessionViewModel, Converter={StaticResource NullToCollapsedConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="{Binding SelectedSessionViewModel.Session.Name}"
                                       Foreground="#F3E9DF"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                            <TextBlock Text="{Binding SelectedSessionViewModel.Session.Provider, Converter={StaticResource ProviderDisplayConverter}}"
                                       Foreground="#D0BFB2"
                                       FontSize="11" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource ToolButton}"
                                Margin="6,0,0,0"
                                ToolTip="Archive"
                                Content="&#xE7B8;"
                                Command="{Binding ArchiveSessionCommand}"
                                CommandParameter="{Binding SelectedSessionViewModel.Session}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource ToolButton}"
                                Margin="6,0,0,0"
                                ToolTip="Close"
                                Content="&#xE711;"
                                Command="{Binding CloseSessionCommand}" />
                    </Grid>

                    <ListView x:Name="MessagesListView"
                              Grid.Row="1"
                              ItemsSource="{Binding SelectedSessionViewModel.VisibleMessages}"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#F3E9DF"
                              VirtualizingStackPanel.IsVirtualizing="False"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="MessagesListView_PreviewMouseWheel">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0,4,0,4" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatMessage}">
                                <Border Background="{Binding Role, Converter={StaticResource MessageRoleToBubbleBrushConverter}}"
                                        BorderBrush="#6A5E54"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        HorizontalAlignment="{Binding Role, Converter={StaticResource MessageRoleToAlignmentConverter}}"
                                        MaxWidth="280">
                                    <Grid>
                                        <!-- Plain text for user / system / error messages. -->
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#FFF3E9DF"
                                                   Visibility="{Binding Role, Converter={StaticResource MessageRoleToPlainVisibilityConverter}}" />

                                        <!-- Markdown rendering for assistant messages (handles streaming). -->
                                        <views:MarkdownTextBlock Markdown="{Binding Content}"
                                                                  ForegroundBrush="#FFF3E9DF"
                                                                  Visibility="{Binding Role, Converter={StaticResource MessageRoleToMarkdownVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Background="#22000000"
                            BorderBrush="#66544A41"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="6,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0"
                                     Text="{Binding SelectedSessionViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32"
                                     MaxHeight="120"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     Background="Transparent"
                                     Foreground="#F3E9DF"
                                     CaretBrush="#F3E9DF"
                                     BorderThickness="0"
                                     Padding="4,4,4,2"
                                     PreviewKeyDown="InputTextBox_PreviewKeyDown" />
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,2,0,0">
                                <Button Style="{StaticResource ToolButton}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip="Attach"
                                        Content="&#xE723;"
                                        Click="AttachButton_Click" />
                                <Button Style="{StaticResource ToolButton}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="2,0,0,0"
                                        ToolTip="Send"
                                        Content="&#xE724;"
                                        Command="{Binding SendCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Stack of floating control circles + chat heads.
                 Orientation flips Vertical/Horizontal based on the user-selected layout mode. -->
            <StackPanel x:Name="HeadColumn"
                        Grid.Row="0"
                        Grid.Column="1"
                        Orientation="{Binding SelectedLayoutMode, Converter={StaticResource LayoutModeToInnerOrientationConverter}}"
                        Background="Transparent">

                <Button Style="{StaticResource CircleControlButton}"
                        Margin="0,0,8,8"
                        ToolTip="New chat"
                        Content="&#xE710;"
                        FontSize="20"
                        Command="{Binding AddSessionCommand}" />

                <Button Style="{StaticResource CircleControlButton}"
                        Margin="0,0,8,8"
                        ToolTip="History"
                        Content="&#xE81C;"
                        Click="HistoryButton_Click" />

                <ItemsControl ItemsSource="{Binding Sessions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="{Binding DataContext.SelectedLayoutMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource LayoutModeToInnerOrientationConverter}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatSession}">
                            <Grid Margin="0,0,8,8" Width="64" Height="64">
                                <Button Style="{StaticResource HeadButton}"
                                        Click="ChatHead_Click"
                                        Tag="{Binding Id}"
                                        ToolTip="{Binding Name}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        views:BobbleAnimations.IsWorking="{Binding State.Kind, Converter={StaticResource SessionStateKindIsRunningConverter}}">
                                    <Grid>
                                        <Ellipse Width="56" Height="56">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding ChatHeadImageName, Converter={StaticResource ChatHeadAvatarConverter}}"
                                                            Stretch="UniformToFill" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>
                                </Button>

                                <!-- Status indicator dot (top-right). -->
                                <Ellipse Width="14"
                                         Height="14"
                                         Fill="{Binding State, Converter={StaticResource SessionStatusToBrushConverter}}"
                                         Stroke="#25221F"
                                         StrokeThickness="2"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,2,2,0"
                                         Visibility="{Binding ., Converter={StaticResource SessionToStatusVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- History flyout panel -->
        <Border x:Name="HistoryPopup"
                Width="280"
                MaxHeight="360"
                Background="#F22E2A26"
                BorderBrush="#66544A41"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,80,80,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="History" Foreground="#F3E9DF" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ScrollViewer Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding HistorySessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatSession}">
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               Foreground="#F3E9DF"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ToolButton}"
                                            Margin="6,0,0,0"
                                            ToolTip="Open"
                                            Content="&#xE8A7;"
                                            Click="RestoreHistory_Click"
                                            Tag="{Binding Id}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource ToolButton}"
                                            Margin="6,0,0,0"
                                            ToolTip="Delete"
                                            Content="&#xE74D;"
                                            Click="DeleteHistory_Click"
                                            Tag="{Binding Id}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
