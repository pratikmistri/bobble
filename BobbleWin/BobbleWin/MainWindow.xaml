<Window x:Class="BobbleWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:BobbleWin.Models"
        xmlns:views="clr-namespace:BobbleWin.Views"
        Title="Bobble"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <views:ProviderDisplayConverter x:Key="ProviderDisplayConverter" />
        <views:MessageRoleToAlignmentConverter x:Key="MessageRoleToAlignmentConverter" />
        <views:MessageRoleToBubbleBrushConverter x:Key="MessageRoleToBubbleBrushConverter" />
        <views:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <views:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <views:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <views:ChatHeadAvatarConverter x:Key="ChatHeadAvatarConverter" />

        <FontFamily x:Key="FluentIcons">Segoe Fluent Icons</FontFamily>

        <Style TargetType="Thumb" x:Key="ShyScrollThumb">
            <Setter Property="Background" Value="#80F3E9DF" />
            <Setter Property="Width" Value="4" />
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="MaxWidth" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="2"
                                Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RepeatButton" x:Key="ShyScrollRepeat">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" x:Key="ShyScrollBar">
            <Setter Property="Width" Value="4" />
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="MaxWidth" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="4">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ShyScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ShyScrollRepeat}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ShyScrollRepeat}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource ShyScrollBar}" />

        <Style x:Key="CircleControlButton" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F3E9DF" />
            <Setter Property="FontFamily" Value="{StaticResource FluentIcons}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="#CC25221F" Stroke="#66F3E9DF" StrokeThickness="1" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeadButton" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="#33000000" />
            <Setter Property="Foreground" Value="#F3E9DF" />
            <Setter Property="BorderBrush" Value="#66544A41" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="{StaticResource FluentIcons}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">

            <!-- Expanded chat panel (visible when a session is selected) -->
            <Border Width="340"
                    Height="500"
                    Margin="0,0,14,0"
                    Background="#F22E2A26"
                    BorderBrush="#66544A41"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12"
                    Visibility="{Binding SelectedSessionViewModel, Converter={StaticResource NullToCollapsedConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="{Binding SelectedSessionViewModel.Session.Name}"
                                       Foreground="#F3E9DF"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                            <TextBlock Text="{Binding SelectedSessionViewModel.Session.Provider, Converter={StaticResource ProviderDisplayConverter}}"
                                       Foreground="#D0BFB2"
                                       FontSize="11" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource ToolButton}"
                                Margin="6,0,0,0"
                                ToolTip="Archive"
                                Content="&#xE7B8;"
                                Command="{Binding ArchiveSessionCommand}"
                                CommandParameter="{Binding SelectedSessionViewModel.Session}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource ToolButton}"
                                Margin="6,0,0,0"
                                ToolTip="Close"
                                Content="&#xE711;"
                                Command="{Binding CloseSessionCommand}" />
                    </Grid>

                    <ListView x:Name="MessagesListView"
                              Grid.Row="1"
                              ItemsSource="{Binding SelectedSessionViewModel.VisibleMessages}"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#F3E9DF"
                              VirtualizingStackPanel.IsVirtualizing="False"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="MessagesListView_PreviewMouseWheel">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0,4,0,4" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatMessage}">
                                <Border Background="{Binding Role, Converter={StaticResource MessageRoleToBubbleBrushConverter}}"
                                        BorderBrush="#6A5E54"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        HorizontalAlignment="{Binding Role, Converter={StaticResource MessageRoleToAlignmentConverter}}"
                                        MaxWidth="280">
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap"
                                               Foreground="#FFF3E9DF" />
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SelectedSessionViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="40"
                                 MaxHeight="100"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Center"
                                 Background="#22000000"
                                 Foreground="#F3E9DF"
                                 BorderBrush="#66544A41"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 PreviewKeyDown="InputTextBox_PreviewKeyDown" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ToolButton}"
                                Margin="6,0,0,0"
                                ToolTip="Attach"
                                Content="&#xE723;"
                                Click="AttachButton_Click" />
                        <Button Grid.Column="2"
                                Style="{StaticResource ToolButton}"
                                Margin="6,0,0,0"
                                ToolTip="Send"
                                Content="&#xE724;"
                                Command="{Binding SendCommand}" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Vertical column of floating control circles + chat heads -->
            <StackPanel x:Name="HeadColumn"
                        Orientation="Vertical"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        MouseLeftButtonDown="HeadColumn_MouseLeftButtonDown">

                <Button Style="{StaticResource CircleControlButton}"
                        Margin="0,0,0,8"
                        ToolTip="New chat"
                        Content="&#xE710;"
                        FontSize="20"
                        Command="{Binding AddSessionCommand}" />

                <Button Style="{StaticResource CircleControlButton}"
                        Margin="0,0,0,8"
                        ToolTip="History"
                        Content="&#xE81C;"
                        Click="HistoryButton_Click" />

                <ItemsControl ItemsSource="{Binding Sessions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatSession}">
                            <Button Style="{StaticResource HeadButton}"
                                    Margin="0,0,0,8"
                                    Click="ChatHead_Click"
                                    Tag="{Binding Id}">
                                <Grid>
                                    <Ellipse Width="56" Height="56">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ChatHeadImageName, Converter={StaticResource ChatHeadAvatarConverter}}"
                                                        Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse Width="14"
                                            Height="14"
                                            Fill="#E3B56E"
                                            Stroke="#25221F"
                                            StrokeThickness="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding HasUnread, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>

        <!-- History flyout panel -->
        <Border x:Name="HistoryPopup"
                Width="280"
                MaxHeight="360"
                Background="#F22E2A26"
                BorderBrush="#66544A41"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,80,80,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="History" Foreground="#F3E9DF" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ScrollViewer Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding HistorySessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatSession}">
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               Foreground="#F3E9DF"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ToolButton}"
                                            Margin="6,0,0,0"
                                            ToolTip="Open"
                                            Content="&#xE8A7;"
                                            Click="RestoreHistory_Click"
                                            Tag="{Binding Id}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource ToolButton}"
                                            Margin="6,0,0,0"
                                            ToolTip="Delete"
                                            Content="&#xE74D;"
                                            Click="DeleteHistory_Click"
                                            Tag="{Binding Id}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
